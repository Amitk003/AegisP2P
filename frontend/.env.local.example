NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=deployed_contract_address_here
NEXT_PUBLIC_RECLAIM_APP_ID=your_reclaim_app_id
# RECLAIM_APP_SECRET is server-only. Do NOT add NEXT_PUBLIC_ prefix.
# It is used in API routes / server actions, never exposed to the browser.
RECLAIM_APP_SECRET=your_reclaim_app_secret
